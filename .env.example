# ── Supabase (all environments) ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key            # safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key        # server-only — never expose

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Runtime (serverless routes): transaction pooler, port 6543 (prepare=false).
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# NOTE: for `drizzle-kit push` / `db:migrate`, point DATABASE_URL at the DIRECT
# connection (port 5432) instead of the pooler.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate limiting (optional) ─────────────────────────────────────────────────
# Set both for cross-instance rate limiting via Upstash Redis; unset = per-
# instance in-memory fallback (fine for dev/single-instance).
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ── Billing (optional, future) ───────────────────────────────────────────────
# Stripe webhook is inert (503) until the secret is set. Point a Stripe webhook
# at POST /api/webhooks/stripe with client_reference_id = tenantId.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Error monitoring (optional) ──────────────────────────────────────────────
# Set to enable Sentry; unset = no-op. Server uses SENTRY_DSN, client the public.
# SENTRY_DSN=https://...@oXXXX.ingest.sentry.io/XXXX
# NEXT_PUBLIC_SENTRY_DSN=https://...@oXXXX.ingest.sentry.io/XXXX

# ── Seed (optional) ──────────────────────────────────────────────────────────
# Grant the first TENANT_ADMIN to an existing Supabase Auth user.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_USER_ID=<supabase-auth-user-uuid>
