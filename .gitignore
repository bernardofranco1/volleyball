# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# CI workflow held locally until the gh token has 'workflow' scope.
# Re-enable with: gh auth refresh -h github.com -s workflow && git add -f .github/workflows/ci.yml
/.github/workflows/

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
_validate-*.mts
